# compose 用の環境変数テンプレート。
# 使い方: cp .env.example .env して値を自分のものに変更（.env はGit管理外）。
# SECRET_KEY は英数字推奨（記号は .env の引用でハマりやすい）。次で生成可:
#   python3 -c "import secrets,string;print(''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(64)))"

SECRET_KEY=change-me-64-alphanumeric
DB_PASSWORD=change-me-app-db-password
DB_ROOT_PASSWORD=change-me-root-password
ALLOWED_HOSTS=localhost,127.0.0.1

# 公開ポート（既定80）。ホストの80が埋まっている等で変えたいとき:
# HTTP_PORT=8080
